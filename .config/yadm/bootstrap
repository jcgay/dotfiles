#!/bin/bash
set -e

echo "=== yadm bootstrap ==="

# Demande la classe si non configurée
if [ -z "$(yadm config local.class)" ]; then
  echo "Quelle est la classe de cette machine ?"
  select class in "Work" "Personal"; do
    yadm config local.class "$class"
    yadm alt
    break
  done
fi

# Installe Homebrew si absent
if ! command -v brew &>/dev/null; then
  echo "Installation de Homebrew..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

# Trust brew tap
echo "Ajout des tap de confiance..."
brew trust jcgay/jcgay
brew trust mvndaemon/homebrew-mvnd
brew trust wagoodman/dive
brew trust moul/moul
brew trust mthmulders/tap
brew trust jakewharton/repo
brew trust raullenchai/rapid-mlx
brew trust static-var/tap

# Installe toutes les dépendances via Brewfile
echo "Installation des formules Homebrew..."
brew bundle --global

# git lfs
git lfs install

# Change le shell par défaut vers fish
if [ "$SHELL" != "/opt/homebrew/bin/fish" ]; then
  echo "Changement du shell vers fish..."
  if ! grep -q /opt/homebrew/bin/fish /etc/shells; then
    echo /opt/homebrew/bin/fish | sudo tee -a /etc/shells
  fi
  chsh -s /opt/homebrew/bin/fish
fi

# Répertoire workspace Go
echo "Création du workspace Go..."
mkdir -p ~/dev/golang/{src,bin,pkg}

# Volta (JavaScript version manager)
if ! command -v volta &>/dev/null; then
  echo "Installation de Volta..."
  curl https://get.volta.sh | bash
fi

# SonarQube CLI (pas de formule brew — installe dans ~/.local/share/sonarqube-cli)
if [ ! -x "$HOME/.local/share/sonarqube-cli/bin/sonar" ]; then
  echo "Installation de SonarQube CLI..."
  curl -o- https://raw.githubusercontent.com/SonarSource/sonarqube-cli/refs/heads/master/user-scripts/install.sh | bash
fi

# mise — installe tous les outils JVM (Java, Gradle, Kotlin, etc.)
echo "Installation des outils JVM via mise..."
mise install

# Fisher (fish plugin manager)
echo "Installation de fisher et plugins fish..."
fish -c 'curl -sL https://raw.githubusercontent.com/jorgebucaran/fisher/main/functions/fisher.fish | source && fisher install < ~/.config/fish/fish_plugins'

# Claude Code — marketplaces, plugins, serveurs MCP (claude vient du Brewfile)
# (build-brief est exclu : marketplace locale gérée par son propre installeur)
if command -v claude &>/dev/null; then
  echo "Configuration de Claude Code (plugins + MCP)..."

  # Marketplaces tierces (claude-plugins-official est déjà connue par défaut)
  claude plugin marketplace add forrestchang/andrej-karpathy-skills || true
  claude plugin marketplace add DietrichGebert/ponytail || true

  # Plugins (scope user par défaut) — || true pour rester ré-exécutable
  for plugin in \
    superpowers@claude-plugins-official \
    context7@claude-plugins-official \
    jdtls-lsp@claude-plugins-official \
    typescript-lsp@claude-plugins-official \
    pyright-lsp@claude-plugins-official \
    sonarqube@claude-plugins-official \
    frontend-design@claude-plugins-official \
    andrej-karpathy-skills@karpathy-skills \
    ponytail@ponytail; do
    claude plugin install "$plugin" || true
  done

  # Serveur MCP codebase-memory (nécessite le binaire ~/.local/bin/codebase-memory-mcp)
  if [ -x "$HOME/.local/bin/codebase-memory-mcp" ]; then
    claude mcp add -s user codebase-memory-mcp "$HOME/.local/bin/codebase-memory-mcp" || true
  else
    echo "ℹ️  codebase-memory-mcp absent — MCP non enregistré (installer le binaire d'abord)."
  fi
else
  echo "ℹ️  CLI 'claude' absente — section Claude Code ignorée (relancer après installation)."
fi

# Restauration des configs apps via mackup
echo ""
echo "⚠️  Assurez-vous que Dropbox est synchronisé avant de continuer."
read -p "Continuer avec mackup restore ? [y/N] " confirm
if [[ "$confirm" == "y" || "$confirm" == "Y" ]]; then
  mackup restore
  echo "✅  mackup restore terminé."
else
  echo "ℹ️  Skipping mackup restore. Relancer manuellement avec : mackup restore"
fi

echo ""
echo "✅  Bootstrap terminé !"
echo "ℹ️  Relancer le shell pour appliquer tous les changements."
