#!/bin/sh
#
# post_pull — reconcile local config when the source files change during a
# `yadm pull` (also triggered via the `dot` script).

# True if $1 changed within the pulled range (ORIG_HEAD..HEAD).
changed() {
  ! yadm diff --quiet ORIG_HEAD HEAD -- "$1" 2>/dev/null
}

# Re-render ##template files (idempotent, no diff check needed).
yadm alt

# ─── Homebrew: .Brewfile ─────────────────────────────────────────────────
if command -v brew >/dev/null 2>&1 && changed .Brewfile; then
  echo "\033[0;34m.Brewfile changed — syncing Homebrew…\033[0m"
  # Additions (and any missing entry): brew bundle handles it.
  brew bundle --global install
  # Removals: uninstall the formulae/casks dropped from the Brewfile.
  # ponytail: basic `-brew "x"` / `-cask "x"` parse, ignores mas/tap.
  diff=$(yadm diff --unified=0 ORIG_HEAD HEAD -- .Brewfile 2>/dev/null)
  echo "$diff" | sed -n 's/^-brew "\([^"]*\)".*/\1/p'  | while read -r f; do
    brew uninstall "$f" 2>/dev/null || true
  done
  echo "$diff" | sed -n 's/^-cask "\([^"]*\)".*/\1/p' | while read -r c; do
    brew uninstall --cask "$c" 2>/dev/null || true
  done
fi

# ─── mise: .config/mise/config.toml ──────────────────────────────────────
if command -v mise >/dev/null 2>&1 && changed .config/mise/config.toml; then
  echo "\033[0;34mmise config changed — mise install…\033[0m"
  mise install
fi

# ─── Fisher: .config/fish/fish_plugins ───────────────────────────────────
if command -v fish >/dev/null 2>&1 && changed .config/fish/fish_plugins; then
  echo "\033[0;34mfish_plugins changed — fisher update…\033[0m"
  fish -c "fisher update"
fi
