#!/bin/sh
#
# post_pull — sync Homebrew si .Brewfile a changé pendant le pull.
#   - ajouts   : `brew bundle --global install` (idempotent, gère tout)
#   - retraits : uninstall des lignes brew/cask disparues du diff

command -v brew >/dev/null 2>&1 || exit 0

diff=$(yadm diff --unified=0 ORIG_HEAD HEAD -- .Brewfile 2>/dev/null)
[ -n "$diff" ] || exit 0

echo "\033[0;34m.Brewfile modifié — synchro Homebrew…\033[0m"

# Ajouts (et toute autre entrée manquante) : brew bundle s'en occupe.
brew bundle --global install

# Retraits : uninstall uniquement des formules/casks retirés du Brewfile.
# ponytail: parse basique `-brew "x"` / `-cask "x"`, ignore mas/tap. Étendre si besoin.
echo "$diff" | sed -n 's/^-brew "\([^"]*\)".*/\1/p'  | while read -r f; do
  brew uninstall "$f" 2>/dev/null || true
done
echo "$diff" | sed -n 's/^-cask "\([^"]*\)".*/\1/p' | while read -r c; do
  brew uninstall --cask "$c" 2>/dev/null || true
done
